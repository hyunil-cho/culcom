<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.culcom.mapper.WebhookLogQueryMapper">

    <sql id="searchCondition">
        <where>
            <choose>
                <when test="webhookSeq != null">
                    wl.webhook_config_seq = #{webhookSeq}
                </when>
                <otherwise>
                    wl.branch_seq = #{branchSeq}
                    <if test="status != null and status != ''">
                        AND wl.status = #{status}
                    </if>
                </otherwise>
            </choose>
        </where>
    </sql>

    <select id="search" resultType="com.culcom.dto.webhook.WebhookLogResponse">
        SELECT
            wl.seq,
            wl.webhook_config_seq AS webhookConfigSeq,
            wl.customer_seq AS customerSeq,
            wl.branch_seq AS branchSeq,
            wl.source_name AS sourceName,
            wl.raw_request AS rawRequest,
            wl.parsed_params AS parsedParams,
            wl.mapped_data AS mappedData,
            wl.http_status_code AS httpStatusCode,
            wl.status,
            wl.error_message AS errorMessage,
            wl.remote_ip AS remoteIp,
            wl.created_date AS createdDate
        FROM webhook_logs wl
        <include refid="searchCondition"/>
        ORDER BY wl.created_date DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="count" resultType="int">
        SELECT COUNT(*)
        FROM webhook_logs wl
        <include refid="searchCondition"/>
    </select>

</mapper>
